{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "Read",
      "Edit",
      "Write",
      "Bash(ls *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(go *)",
      "Bash(docker *)",
      "Bash(rg *)",
      "Bash(make *)",
      "Bash(npm *)",
      "Bash(echo *)",
      "Bash(cat *)",
      "Bash(find *)"
    ],
    "deny": [
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.netrc)",
      "Read(~/.npmrc)",
      "Read(~/.docker/config.json)",
      "Read(~/.kube/config)",
      "Read(~/.config/**)",
      "Read(**/.env)",
      "Read(**/.env.*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/genshijin-activate.js\"",
            "timeout": 5,
            "statusMessage": "原始人モード起動中..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/genshijin-mode-tracker.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'MSG=$(cat | jq -r \".message // \\\"Claude Codeが入力を待っています\\\"\"); osascript -e \"display notification \\\"$MSG\\\" with title \\\"Claude Code\\\" sound name \\\"Hero\\\"\"'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/doc-file-warning.js\""
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/skills/strategic-compact/suggest-compact.sh\""
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/skills/strategic-compact/suggest-compact.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/post-edit-typecheck.js\""
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash \"$HOME/.claude/statusline.sh\""
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "genshijin@genshijin": true
  },
  "extraKnownMarketplaces": {
    "genshijin": {
      "source": {
        "source": "github",
        "repo": "InterfaceX-co-jp/genshijin"
      }
    }
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowedDomains": [
        "github.com",
        "api.github.com",
        "*.githubusercontent.com"
      ],
      "allowLocalBinding": true
    },
    "filesystem": {
      "allowRead": [
        "~/.config/gh/*",
        "~/.config/git/config"
      ]
    },
    "enableWeakerNetworkIsolation": true
  },
  "defaultMode": "auto"
}
